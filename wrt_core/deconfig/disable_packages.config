# =========================================
# 明确禁用不需要的包
# 此文件必须最后加载以确保禁用生效
# =========================================

# 禁用 iStore 相关（不需要应用商店）
CONFIG_PACKAGE_luci-app-store=n
CONFIG_PACKAGE_luci-app-istorex=n
CONFIG_PACKAGE_luci-app-quickstart=n

# 禁用 mosdns（使用 smartdns 和 adguardhome）
CONFIG_PACKAGE_luci-app-mosdns=n
CONFIG_PACKAGE_mosdns=n
CONFIG_PACKAGE_v2ray-geoip=n
CONFIG_PACKAGE_v2ray-geosite=n

# 禁用 Passwall
CONFIG_PACKAGE_luci-app-passwall=n
